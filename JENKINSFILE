pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/cser-bhavya-khandelwal/sample_java.git'
            }
        }
         stage('Hello') {
            steps {
                bat '''
                javac Test.java
                java Test.java
                '''
            }
        }
    }
}
